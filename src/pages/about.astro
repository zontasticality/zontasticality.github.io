---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="about" description="About me — placeholder">
  <h1>about</h1>

  <p>
    [bio placeholder — replace with your real intro: who you are, what you
    work on, what you care about. Aim for ~3 short paragraphs. The
    bettermotherfucking aesthetic rewards plain talk.]
  </p>

  <p>
    [paragraph 2 — current focus. e.g. "Right now I'm building a programming
    language that...", or "I'm finishing my division III on Bayesian..."]
  </p>

  <p>
    [paragraph 3 — what you want from this page. Reach out? Follow? Read?]
  </p>

  <h2>elsewhere</h2>
  <ul>
    <li><a href="https://github.com/zontasticality">github</a></li>
    <li>[email / mastodon / twitter / etc — TBD]</li>
  </ul>

  <h2>courses</h2>
  <p>
    [optional intro line about what these are — e.g. "Notes and writeups
    from courses I've taken at Hampshire and elsewhere."]
  </p>
  <ul class="courses">
    <li>
      <strong>[course name]</strong> · [term]
      <br />
      <span class="muted">[one-line description or link to notes]</span>
    </li>
    <li>
      <strong>[course name]</strong> · [term]
      <br />
      <span class="muted">[one-line description or link to notes]</span>
    </li>
    <li>
      <strong>[course name]</strong> · [term]
      <br />
      <span class="muted">[one-line description or link to notes]</span>
    </li>
  </ul>
</BaseLayout>

<style>
  .courses { list-style: none; padding: 0; }
  .courses li { margin-bottom: 0.9em; }
  .muted { color: var(--fg-muted); font-size: 0.92em; }
</style>
