---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  phases,
  courseExtras,
  auditedCourses,
  type Phase,
} from '../data/courses.ts';

/* ─── Tiny RFC 4180 CSV parser (handles quoted commas) ──────── */
function parseCsv(text: string): string[][] {
  const rows: string[][] = [];
  let row: string[] = [];
  let cur = '';
  let inQ = false;
  for (let i = 0; i < text.length; i++) {
    const c = text[i];
    if (inQ) {
      if (c === '"') {
        if (text[i + 1] === '"') { cur += '"'; i++; }
        else inQ = false;
      } else cur += c;
    } else {
      if (c === '"') inQ = true;
      else if (c === ',') { row.push(cur); cur = ''; }
      else if (c === '\n') { row.push(cur); rows.push(row); row = []; cur = ''; }
      else if (c === '\r') { /* skip */ }
      else cur += c;
    }
  }
  if (cur || row.length) { row.push(cur); rows.push(row); }
  return rows.filter(r => r.length > 1);
}

interface TranscriptRow {
  year: string;
  class_code: string;
  name: string;
  school: string;
  faculty: string;
  final_eval: string;
  eval_text: string;
}

const csvPath = path.resolve('./data/classes.csv');
const raw = fs.readFileSync(csvPath, 'utf8');
const rows = parseCsv(raw);
const [, ...body] = rows;
const transcript: TranscriptRow[] = body.map(r => ({
  year: r[0] ?? '',
  class_code: r[1] ?? '',
  name: r[2] ?? '',
  school: r[3] ?? '',
  faculty: r[4] ?? '',
  final_eval: r[5] ?? '',
  eval_text: r[6] ?? '',
}));

interface HsClassRow {
  year: string;
  course_code: string;
  section: string;
  name: string;
  teacher: string;
  sem1: string;
  sem2: string;
  final: string;
  comment_codes: string[]; // split from semicolon-separated
  credit: string;
}

const hsClassesPath = path.resolve('./data/highschool_classes.csv');
const hsClassesRaw = fs.readFileSync(hsClassesPath, 'utf8');
const hsClassesRows = parseCsv(hsClassesRaw);
const [, ...hsClassesBody] = hsClassesRows;
const hsClasses: HsClassRow[] = hsClassesBody.map(r => ({
  year: r[0] ?? '',
  course_code: r[1] ?? '',
  section: r[2] ?? '',
  name: r[3] ?? '',
  teacher: r[4] ?? '',
  sem1: r[5] ?? '',
  sem2: r[6] ?? '',
  final: r[7] ?? '',
  comment_codes: (r[8] ?? '').split(';').map(s => s.trim()).filter(Boolean),
  credit: r[9] ?? '',
}));

const hsCommentsPath = path.resolve('./data/highschool_comments.csv');
const hsCommentsRaw = fs.readFileSync(hsCommentsPath, 'utf8');
const hsCommentsRows = parseCsv(hsCommentsRaw);
const [, ...hsCommentsBody] = hsCommentsRows;
const hsCommentMeaning: Record<string, string> = {};
for (const r of hsCommentsBody) {
  if (r[0]) hsCommentMeaning[r[0]] = r[1] ?? '';
}

// CSV `Other` rows (transfer/AP credit) are surfaced under the HS phase
// instead, via Phase.hsClasses — drop them from the term map.
const byTerm = new Map<string, TranscriptRow[]>();
for (const t of transcript) {
  if (t.year === 'Other') continue;
  if (!byTerm.has(t.year)) byTerm.set(t.year, []);
  byTerm.get(t.year)!.push(t);
}
const auditedByTerm = new Map<string, typeof auditedCourses>();
for (const a of auditedCourses) {
  if (!auditedByTerm.has(a.year)) auditedByTerm.set(a.year, []);
  auditedByTerm.get(a.year)!.push(a);
}

// Sort phases newest first.
const orderedPhases = [...phases].sort((a, b) =>
  a.sortKey < b.sortKey ? 1 : a.sortKey > b.sortKey ? -1 : 0
);

function evalDisplay(e: string): { kind: 'grade' | 'accepted' | 'inprogress' | 'none'; text: string } {
  if (!e) return { kind: 'none', text: '' };
  if (e.toLowerCase() === 'accepted') return { kind: 'accepted', text: 'accepted' };
  if (e.toUpperCase() === 'N/A') return { kind: 'inprogress', text: 'in progress' };
  return { kind: 'grade', text: e };
}

function extrasFor(year: string, code: string) {
  return courseExtras[`${year}:${code}`] ?? {};
}

function classesForPhase(p: Phase) {
  if (!p.term) return null;
  const trans = byTerm.get(p.term) ?? [];
  const aud = auditedByTerm.get(p.term) ?? [];
  if (trans.length === 0 && aud.length === 0) return null;
  return { trans, aud };
}
---
<BaseLayout title="history" description="Academic + work timeline">
  <h1>academic history</h1>
  <p class="intro">
    Reverse-chronological. All the classes, research, and anything else I've been working on.
  </p>

  <div class="timeline">
    {orderedPhases.map((p) => {
      const cls = classesForPhase(p);
      return (
        <section class="phase-block" id={p.id}>
          <header class={`phase-card phase-kind-${p.kindLabel.toLowerCase().replace(/\s+/g, '-')}`}>
            <span class="kind-badge">{p.kindLabel}</span>
            <h2 class="title">{p.title}</h2>
            {p.subtitle && <p class="subtitle">{p.subtitle}</p>}
            {p.featuredLink && (
              <p class="featured-link">
                <a href={p.featuredLink.href}>{p.featuredLink.label}</a>
              </p>
            )}
            {p.description && <p class="description">{p.description}</p>}
            {p.links && p.links.length > 0 && (
              <ul class="links">
                {p.links.map((l) => (
                  <li>
                    <a href={l.href}>{l.label}</a>
                    {l.note && <span class="muted"> — {l.note}</span>}
                  </li>
                ))}
              </ul>
            )}
            {p.bullets && p.bullets.length > 0 && (
              <ul class="bullets">
                {p.bullets.map((b) => <li>{b}</li>)}
              </ul>
            )}
            {p.awards && p.awards.length > 0 && (
              <div class="awards">
                <span class="sub-label">Awards</span>
                <ul>{p.awards.map((a) => <li>{a}</li>)}</ul>
              </div>
            )}
            {p.testScores && p.testScores.length > 0 && (
              <div class="test-scores">
                <span class="sub-label">Test scores</span>
                <ul>{p.testScores.map((t) => (
                  <li><strong>{t.label}</strong> <span class="muted">{t.score}</span></li>
                ))}</ul>
              </div>
            )}
            {p.apExams && p.apExams.length > 0 && (
              <div class="ap-exams">
                <span class="sub-label">AP exams</span>
                <ul>{p.apExams.map((c) => <li>{c}</li>)}</ul>
              </div>
            )}
            {p.id === 'highschool' && hsClasses.length > 0 && (
              <>
                <span class="sub-label">Senior year classes</span>
                <ul class="hs-class-list">
                  {hsClasses.map((c) => {
                    const passOnly = c.final === 'P';
                    return (
                      <li class="hs-row">
                        <span class="hs-name" title={c.name}>
                          {c.name}
                          {c.section && c.course_code === '3304' && (
                            <span class="muted"> · sec {c.section}</span>
                          )}
                        </span>
                        <span class="hs-teacher muted" title={c.teacher}>{c.teacher}</span>
                        <span class={`hs-final ${passOnly ? 'pass' : ''}`}>{c.final}</span>
                        {c.comment_codes.length > 0 && (
                          <span class="hs-codes">
                            {c.comment_codes.map((code) => (
                              <span class="code-badge" title={hsCommentMeaning[code] ?? code}>{code}</span>
                            ))}
                          </span>
                        )}
                      </li>
                    );
                  })}
                </ul>
              </>
            )}
          </header>

          {cls && (
            <ul class="courses">
              {cls.trans.map((r) => {
                const ex = extrasFor(r.year, r.class_code);
                const facultyName = ex.facultyDisplay || r.faculty;
                const ev = evalDisplay(r.final_eval);
                return (
                  <li class="course">
                    <span class="code">{r.class_code}</span>
                    <span class="name" title={r.name}>
                      {ex.courseUrl
                        ? <a href={ex.courseUrl}>{r.name}</a>
                        : r.name}
                      {ex.paperUrl && (
                        <> <a class="aux" href={ex.paperUrl}>(paper)</a></>
                      )}
                      {ex.notesUrl && (
                        <> <a class="aux" href={ex.notesUrl}>(notes)</a></>
                      )}
                    </span>
                    <span class="school">{r.school}</span>
                    <span class="faculty" title={facultyName || undefined}>
                      {facultyName ? (
                        ex.facultyUrl
                          ? <a href={ex.facultyUrl}>{facultyName}</a>
                          : <span>{facultyName}</span>
                      ) : <span class="muted">—</span>}
                    </span>
                    <span class={`eval eval-${ev.kind}`}>{ev.text || '—'}</span>
                  </li>
                );
              })}
              {cls.aud.map((a) => {
                const audFac = a.facultyDisplay || a.faculty;
                return (
                  <li class="course audited">
                    <span class="code">{a.class_code || '—'}</span>
                    <span class="name" title={a.name}>
                      {a.courseUrl
                        ? <a href={a.courseUrl}>{a.name}</a>
                        : a.name}
                      {a.paperUrl && (
                        <> <a class="aux" href={a.paperUrl}>(paper)</a></>
                      )}
                      {a.notesUrl && (
                        <> <a class="aux" href={a.notesUrl}>(notes)</a></>
                      )}
                    </span>
                    <span class="school">{a.school}</span>
                    <span class="faculty" title={audFac || undefined}>
                      {audFac ? (
                        a.facultyUrl
                          ? <a href={a.facultyUrl}>{audFac}</a>
                          : <span>{audFac}</span>
                      ) : <span class="muted">—</span>}
                    </span>
                    <span class="eval eval-audited">audited</span>
                  </li>
                );
              })}
            </ul>
          )}
        </section>
      );
    })}

  </div>
</BaseLayout>

<style>
  .intro { color: var(--fg-muted); margin-bottom: 2em; }
  .muted { color: var(--fg-muted); }

  .timeline {
    position: relative;
  }

  .phase-block {
    margin: 1.4em 0 2.2em;
  }

  /* The card-style header for each phase. */
  .phase-card {
    background: var(--card-bg);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 16px 20px;
    margin-bottom: 0.6em;
  }
  .phase-card .kind-badge {
    display: inline-block;
    font-size: 0.7em;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    margin-bottom: 0.35em;
  }
  .phase-card .title {
    font-size: 1.4em;
    line-height: 1.18;
    margin: 0;
    color: var(--fg-strong);
  }
  .phase-card .subtitle {
    font-size: 0.92em;
    color: var(--fg-muted);
    margin: 0.2em 0 0;
  }
  .phase-card .description {
    margin: 0.7em 0 0;
    font-size: 0.94em;
    line-height: 1.55;
  }
  .phase-card .featured-link {
    margin: 0.8em 0 0;
    font-weight: 600;
    font-size: 0.98em;
  }
  .phase-card .featured-link a {
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }
  .phase-card .links {
    margin: 0.7em 0 0;
    padding-left: 1.2em;
    font-size: 0.92em;
    line-height: 1.5;
  }
  .phase-card .links li { margin-bottom: 0.2em; }
  .phase-card .links li:last-child { margin-bottom: 0; }
  .phase-card .bullets {
    margin: 0.6em 0 0;
    padding-left: 1.2em;
    font-size: 0.94em;
  }

  /* Per-kind accent stripe on the left edge of the card. */
  .phase-card { position: relative; overflow: hidden; }
  .phase-card::before {
    content: "";
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 4px;
    background: var(--fg-muted);
    opacity: 0.5;
  }
  .phase-kind-division-i::before     { background: #6b8e7a; opacity: 0.75; }
  .phase-kind-division-ii::before    { background: #7a8eb4; opacity: 0.8; }
  .phase-kind-division-iii::before   { background: #a08bb4; opacity: 0.85; }
  .phase-kind-summer-research::before { background: #b88a6a; opacity: 0.85; }
  .phase-kind-high-school::before     { background: #888888; opacity: 0.55; }

  /* Sub-blocks inside a phase card (awards, test scores, hs classes) */
  .phase-card .sub-label {
    display: block;
    font-size: 0.72em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin: 0.9em 0 0.2em;
  }
  .phase-card .awards ul,
  .phase-card .test-scores ul,
  .phase-card .ap-exams ul {
    margin: 0;
    padding-left: 1.2em;
    font-size: 0.94em;
    line-height: 1.5;
  }
  .phase-card .test-scores li strong { color: var(--fg-strong); }

  /* Senior-year class rows: name | teacher | final | code badges */
  .hs-class-list {
    list-style: none;
    padding: 0;
    margin: 0.3em 0 0;
  }
  .hs-row {
    display: grid;
    grid-template-columns: 1fr 130px 36px auto;
    gap: 10px;
    padding: 5px 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    font-size: 0.92em;
  }
  .hs-row:last-child { border-bottom: 0; }
  .hs-row > * { min-width: 0; }
  .hs-name {
    line-height: 1.3;
    overflow-wrap: anywhere;
  }
  .hs-teacher {
    font-size: 0.86em;
    overflow-wrap: anywhere;
  }
  .hs-final {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86em;
    text-align: right;
    color: var(--fg-strong);
  }
  .hs-final.pass { color: var(--fg-muted); }
  .hs-codes { display: inline-flex; gap: 3px; flex-wrap: wrap; }
  .code-badge {
    display: inline-block;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.72em;
    padding: 1px 5px;
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--fg-muted);
    background: transparent;
    cursor: help;
  }

  /* Course rows under each card. */
  .courses {
    list-style: none;
    padding: 0 4px;
    margin: 0;
  }
  .course {
    display: grid;
    grid-template-columns: 92px 1fr 90px 1fr 90px;
    gap: 10px;
    padding: 6px 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    font-size: 0.94em;
  }
  .course:last-child { border-bottom: 0; }
  /* Required so 1fr cells can shrink below intrinsic content width and ellipsis can engage. */
  .course > * { min-width: 0; }
  .course .code {
    color: var(--fg-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82em;
  }
  .course .name {
    line-height: 1.35;
    /* Wrap by default; break mid-token only if a single unbreakable
       string would otherwise force horizontal overflow. */
    overflow-wrap: anywhere;
  }
  .course .school {
    font-size: 0.82em;
    color: var(--fg-muted);
    text-transform: lowercase;
  }
  .course .faculty {
    font-size: 0.88em;
    color: var(--fg);
    overflow-wrap: anywhere;
  }
  .course .faculty a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--rule);
  }
  .course .faculty a:hover {
    text-decoration-color: currentColor;
    color: var(--link);
  }
  /* Inline superscript for (notes), (paper), and any other auxiliary
     artifact links — sits next to the class name like a footnote marker. */
  .course .aux {
    font-size: 0.65em;
    vertical-align: super;
    line-height: 0;
    margin-left: 2px;
    color: var(--fg-muted);
    text-decoration: underline;
    text-decoration-color: var(--rule);
  }
  .course .aux:hover {
    color: var(--link);
    text-decoration-color: currentColor;
  }
  .course .eval {
    font-size: 0.82em;
    text-align: right;
    color: var(--fg-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .eval-grade { color: var(--fg-strong); }
  .eval-accepted { color: var(--fg); font-style: italic; font-family: inherit; }
  .eval-inprogress { color: var(--fg-muted); }
  .eval-audited { color: var(--fg-muted); font-style: italic; font-family: inherit; }
  .course.audited .name,
  .course.audited .name a { color: var(--fg-muted); }

  @media (max-width: 720px) {
    .course {
      grid-template-columns: 80px 1fr 70px;
      grid-template-areas:
        "code name eval"
        ".    fac  school";
      row-gap: 2px;
    }
    .course .code { grid-area: code; }
    .course .name { grid-area: name; }
    .course .eval { grid-area: eval; }
    .course .faculty { grid-area: fac; }
    .course .school { grid-area: school; text-align: right; }
    .phase-card { padding: 14px 16px; }
    .phase-card .title { font-size: 1.2em; }
    .hs-row {
      grid-template-columns: 1fr 50px;
      grid-template-areas:
        "name final"
        "teach codes";
      row-gap: 1px;
    }
    .hs-name { grid-area: name; }
    .hs-final { grid-area: final; }
    .hs-teacher { grid-area: teach; }
    .hs-codes { grid-area: codes; justify-self: end; }
  }
</style>
