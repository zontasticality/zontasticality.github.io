---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---
<BaseLayout title="projects" description="Past and ongoing projects">
  <h1>past projects</h1>
  <p>
    Reverse-chronological. Cards link out to the repo.
  </p>

  <ul class="proj-list">
    {projects.map(({ id, data }) => {
      const primary = data.page || data.link;
      const href = primary || '#';
      const isExternal = !!primary;
      const dateLabel = data.dateRange || fmtDate(data.date);
      return (
        <li>
          <a
            class={`proj-card ${data.image ? 'has-image' : 'no-image'}`}
            href={href}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener' : undefined}
          >
            {data.image && (
              <div class="thumb" style={`background-image: url(${data.image});`} />
            )}
            <div class="body">
              <div class="head">
                <h3 class="title">{data.title}</h3>
                <span class="date">{dateLabel}</span>
              </div>
              <p class="summary">{data.summary}</p>
              <div class="foot">
                {data.tags.length > 0 && (
                  <span class="tags">
                    {data.tags.map((t) => <span class="tag">{t}</span>)}
                  </span>
                )}
                {data.status !== 'complete' && (
                  <span class={`status status-${data.status}`}>{data.status}</span>
                )}
              </div>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>

<style>
  .proj-list {
    list-style: none;
    padding: 0;
    margin: 1.5em 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .proj-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    background: var(--card-bg);
    border: 1px solid var(--rule);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 150ms ease, transform 150ms ease;
  }
  .proj-card.no-image { grid-template-columns: 1fr; }
  .proj-card:hover {
    border-color: var(--fg-muted);
    transform: translateY(-1px);
  }
  .proj-card .thumb {
    background-size: cover;
    background-position: center;
    background-color: var(--rule);
    min-height: 140px;
  }
  .proj-card .body {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .proj-card .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .proj-card .title {
    margin: 0;
    font-size: 1.05em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: var(--fg-strong);
  }
  .proj-card .date {
    font-size: 0.82em;
    color: var(--fg-muted);
    white-space: nowrap;
  }
  .proj-card .summary {
    margin: 0;
    font-size: 0.94em;
    line-height: 1.5;
    color: var(--fg);
    overflow-wrap: anywhere;
  }
  .proj-card .foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-top: 4px;
  }
  .proj-card .tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .proj-card .tag {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.72em;
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 1px 6px;
    color: var(--fg-muted);
  }
  .proj-card .status {
    font-size: 0.72em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 1px 6px;
    white-space: nowrap;
  }

  /* Stack thumb on top on narrow screens. */
  @media (max-width: 560px) {
    .proj-card { grid-template-columns: 1fr; }
    .proj-card .thumb { min-height: 160px; }
  }
</style>
