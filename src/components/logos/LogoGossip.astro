---
// Gossip wave: a 3x3 mesh of nodes; messages periodically flash between
// random non-adjacent pairs — the look of an epidemic broadcast protocol.
---
<svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <g class="msgs">
    <line x1="10" y1="10" x2="30" y2="20" />
    <line x1="20" y1="10" x2="10" y2="30" />
    <line x1="30" y1="10" x2="20" y2="30" />
    <line x1="10" y1="20" x2="30" y2="30" />
    <line x1="10" y1="10" x2="20" y2="30" />
    <line x1="30" y1="10" x2="10" y2="20" />
    <line x1="20" y1="10" x2="30" y2="30" />
    <line x1="10" y1="10" x2="30" y2="30" />
  </g>
  <g class="nodes">
    <circle cx="10" cy="10" r="1.5" />
    <circle cx="20" cy="10" r="1.5" />
    <circle cx="30" cy="10" r="1.5" />
    <circle cx="10" cy="20" r="1.5" />
    <circle cx="20" cy="20" r="1.5" />
    <circle cx="30" cy="20" r="1.5" />
    <circle cx="10" cy="30" r="1.5" />
    <circle cx="20" cy="30" r="1.5" />
    <circle cx="30" cy="30" r="1.5" />
  </g>
</svg>

<style>
  svg { stroke: currentColor; fill: currentColor; overflow: visible; }
  .nodes circle { opacity: 0.55; }
  .msgs line {
    stroke-width: 0.5;
    opacity: 0;
    animation: flash 8s ease-in-out infinite;
  }
  .msgs line:nth-child(1) { animation-delay: 0s;   }
  .msgs line:nth-child(2) { animation-delay: 1s;   }
  .msgs line:nth-child(3) { animation-delay: 2s;   }
  .msgs line:nth-child(4) { animation-delay: 3s;   }
  .msgs line:nth-child(5) { animation-delay: 4s;   }
  .msgs line:nth-child(6) { animation-delay: 5s;   }
  .msgs line:nth-child(7) { animation-delay: 6s;   }
  .msgs line:nth-child(8) { animation-delay: 7s;   }
  @keyframes flash {
    0%, 6%, 100% { opacity: 0; stroke-width: 0.4; }
    3%           { opacity: 0.85; stroke-width: 0.9; }
  }
  :global(.brand:hover) .msgs line,
  :global(.logo-host:hover) .msgs line { animation-duration: 2.4s; }
  :global(.brand:hover) .nodes circle,
  :global(.logo-host:hover) .nodes circle { opacity: 0.9; }
</style>
